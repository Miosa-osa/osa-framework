{
  "name": "@miosa/osa",
  "version": "0.1.0",
  "description": "Filesystem-first framework for MIOSA OSA Projects.",
  "type": "module",
  "main": "./src/index.js",
  "bin": {
    "osa": "./src/cli.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./project": "./src/project.js",
    "./manifest": "./src/manifest.js",
    "./skills": "./src/skills.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "docs",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "check": "node --check src/*.js"
  },
  "keywords": [
    "miosa",
    "osa",
    "agent-framework",
    "ai-agents",
    "skills",
    "computers",
    "opencomputers"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Miosa-osa/osa-framework.git"
  },
  "bugs": {
    "url": "https://github.com/Miosa-osa/osa-framework/issues"
  },
  "homepage": "https://github.com/Miosa-osa/osa-framework#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
